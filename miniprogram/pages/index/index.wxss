.page-container {
  padding-bottom: 120rpx;
}

.banner-swiper {
  width: 100%;
  height: 300rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.announcement-bar {
  display: flex;
  align-items: center;
  background-color: #fff8e1;
  padding: 16rpx 24rpx;
}

.announcement-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.announcement-swiper {
  flex: 1;
  height: 40rpx;
}

.announcement-text {
  font-size: 26rpx;
  color: #f57c00;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #4A90D9;
}

.current-play {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  color: #ffffff;
}

.current-play .song-name {
  font-size: 32rpx;
  font-weight: bold;
}

.current-play .singer {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.current-play .play-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.song-list {
  display: flex;
  flex-direction: column;
}

.song-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.song-item:last-child {
  border-bottom: none;
}

.song-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.song-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.song-info .song-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.song-info .singer {
  font-size: 24rpx;
  color: #999999;
}

.play-count {
  font-size: 24rpx;
  color: #999999;
}

.recommend-scroll {
  white-space: nowrap;
}

.recommend-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
}

.recommend-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.recommend-name {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.float-btn image {
  width: 40rpx;
  height: 40rpx;
}

.float-btn text {
  font-size: 22rpx;
  color: #ffffff;
  margin-top: 4rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-container {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.modal-content {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  height: 160rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 30rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background-color: #ffffff;
}

.btn-cancel {
  color: #666666;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #4A90D9;
}

.btn-cancel::after, .btn-confirm::after {
  border: none;
}
