.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  padding: 0 40rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-content {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 24rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 30rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input {
  flex: 1;
  background-color: transparent;
  padding: 24rpx 0;
  font-size: 30rpx;
}

.toggle-password {
  font-size: 36rpx;
  padding: 10rpx;
}

.btn-login {
  background-color: #4A90D9;
  color: #ffffff;
  border-radius: 44rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  margin-top: 30rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

.btn-login[disabled] {
  background-color: #a0c4e8;
}

.login-tips {
  margin-top: 40rpx;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.login-footer {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 60rpx;
  padding-top: 60rpx;
}

.tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
