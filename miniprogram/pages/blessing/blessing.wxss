.page-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.type-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.type-scroll {
  white-space: nowrap;
}

.type-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666666;
}

.type-item.active {
  background-color: #4A90D9;
  color: #ffffff;
}

.form-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.checkbox-row {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 6rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.checkbox.checked {
  background-color: #4A90D9;
  border-color: #4A90D9;
}

.btn-submit {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border-radius: 44rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  border: none;
}

.btn-submit::after {
  border: none;
}

.list-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.blessing-list {
  display: flex;
  flex-direction: column;
}

.blessing-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.blessing-item:last-child {
  border-bottom: none;
}

.blessing-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.blessing-type {
  font-size: 24rpx;
  color: #4A90D9;
  background-color: #e3f2fd;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.blessing-time {
  font-size: 24rpx;
  color: #999999;
}

.blessing-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.blessing-footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}
