.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.user-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  padding: 60rpx 40rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.student-id, .class-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stats-section {
  display: flex;
  background-color: #ffffff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.profile-section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  padding: 24rpx 20rpx 16rpx;
}

.profile-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.profile-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.profile-item:last-child {
  border-bottom: none;
}

.profile-label {
  font-size: 30rpx;
  color: #333;
  width: 160rpx;
}

.profile-value-wrapper {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.profile-value {
  font-size: 30rpx;
  color: #666;
  text-align: right;
}

.profile-value.readonly {
  color: #999;
}

.profile-arrow {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.profile-action {
  font-size: 26rpx;
  color: #4A90D9;
  margin-left: 16rpx;
}

.menu-section {
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.menu-group {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

.badge {
  background-color: #e74c3c;
  color: #ffffff;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.btn-logout {
  background-color: #ffffff;
  color: #e74c3c;
  border-radius: 44rpx;
  margin: 40rpx 20rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  border: none;
}

.btn-logout::after {
  border: none;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-container {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.modal-content {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 30rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background-color: #ffffff;
}

.btn-cancel {
  color: #666666;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #4A90D9;
}

.btn-cancel::after, .btn-confirm::after {
  border: none;
}
