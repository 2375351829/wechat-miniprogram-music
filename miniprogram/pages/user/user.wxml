<view class="page-container">
  <view class="user-header" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || userInfo.real_name || '用户'}}</text>
      <text class="student-id" wx:if="{{userInfo.student_id}}">学号: {{userInfo.student_id}}</text>
      <text class="class-name" wx:if="{{userInfo.class_name}}">{{userInfo.class_name}}</text>
    </view>
  </view>
  
  <view class="user-header" wx:else bindtap="goLogin">
    <image class="avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">点击登录</text>
      <text class="tip">登录后享受更多功能</text>
    </view>
  </view>
  
  <view class="stats-section" wx:if="{{isLoggedIn}}">
    <view class="stat-item">
      <text class="stat-value">{{stats.total_requests || 0}}</text>
      <text class="stat-label">点歌数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.approved_requests || 0}}</text>
      <text class="stat-label">已通过</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.total_blessings || 0}}</text>
      <text class="stat-label">祝福数</text>
    </view>
  </view>
  
  <view class="profile-section" wx:if="{{isLoggedIn}}">
    <view class="section-title">基本信息</view>
    <view class="profile-card">
      <view class="profile-item">
        <text class="profile-label">学号</text>
        <text class="profile-value readonly">{{userInfo.student_id || '未绑定'}}</text>
      </view>
      <view class="profile-item">
        <text class="profile-label">密码</text>
        <view class="profile-value-wrapper">
          <text class="profile-value readonly">******</text>
          <text class="profile-action" bindtap="changePassword">修改</text>
        </view>
      </view>
    </view>
    
    <view class="section-title">个人资料</view>
    <view class="profile-card">
      <view class="profile-item" bindtap="editField" data-field="real_name" data-label="姓名" data-value="{{userInfo.real_name}}">
        <text class="profile-label">姓名</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.real_name || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="nickname" data-label="昵称" data-value="{{userInfo.nickname}}">
        <text class="profile-label">昵称</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.nickname || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="phone" data-label="手机号" data-value="{{userInfo.phone}}">
        <text class="profile-label">手机号</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.phone || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
    </view>
    
    <view class="section-title">学籍信息</view>
    <view class="profile-card">
      <view class="profile-item" bindtap="editField" data-field="college" data-label="学院" data-value="{{userInfo.college}}">
        <text class="profile-label">学院</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.college || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="major" data-label="专业" data-value="{{userInfo.major}}">
        <text class="profile-label">专业</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.major || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="grade" data-label="年级" data-value="{{userInfo.grade}}">
        <text class="profile-label">年级</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.grade || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="class_name" data-label="班级" data-value="{{userInfo.class_name}}">
        <text class="profile-label">班级</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.class_name || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="counselor" data-label="辅导员" data-value="{{userInfo.counselor}}">
        <text class="profile-label">辅导员</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.counselor || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="enrollment_year" data-label="入学年份" data-value="{{userInfo.enrollment_year}}">
        <text class="profile-label">入学年份</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.enrollment_year || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
    </view>
    
    <view class="section-title">微信信息</view>
    <view class="profile-card">
      <view class="profile-item" bindtap="editField" data-field="wechat_name" data-label="微信名称" data-value="{{userInfo.wechat_name}}">
        <text class="profile-label">微信名称</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.wechat_name || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
      <view class="profile-item" bindtap="editField" data-field="wechat_account" data-label="微信账号" data-value="{{userInfo.wechat_account}}">
        <text class="profile-label">微信账号</text>
        <view class="profile-value-wrapper">
          <text class="profile-value">{{userInfo.wechat_account || '未填写'}}</text>
          <text class="profile-arrow">></text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="menu-section" wx:if="{{isLoggedIn}}">
    <view class="menu-group">
      <view class="menu-item" bindtap="viewHistory">
        <image class="menu-icon" src="/images/tab-history.png"></image>
        <text class="menu-text">我的记录</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="viewNotifications">
        <image class="menu-icon" src="/images/logo.png"></image>
        <text class="menu-text">消息通知</text>
        <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
        <text class="menu-arrow">></text>
      </view>
    </view>
    
    <view class="menu-group">
      <view class="menu-item" bindtap="showAbout">
        <image class="menu-icon" src="/images/tab-user.png"></image>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="showFeedback">
        <image class="menu-icon" src="/images/icon-edit.png"></image>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>
  
  <button class="btn-logout" wx:if="{{isLoggedIn}}" bindtap="logout">退出登录</button>
</view>

<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal"></view>
<view class="modal-container" wx:if="{{showEditModal}}">
  <view class="modal-header">
    <text class="modal-title">编辑{{editLabel}}</text>
    <text class="modal-close" bindtap="closeEditModal">×</text>
  </view>
  <view class="modal-content">
    <view class="form-group">
      <input class="form-input" placeholder="请输入{{editLabel}}" value="{{editValue}}" bindinput="onEditInput" maxlength="{{maxLength}}" />
      <text class="form-hint" wx:if="{{editField === 'phone'}}">请输入11位手机号</text>
      <text class="form-hint" wx:if="{{editField === 'enrollment_year'}}">请输入4位年份，如2024</text>
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="closeEditModal">取消</button>
    <button class="btn-confirm" bindtap="saveField" loading="{{saving}}">保存</button>
  </view>
</view>

<view class="modal-mask" wx:if="{{showPasswordModal}}" bindtap="closePasswordModal"></view>
<view class="modal-container" wx:if="{{showPasswordModal}}">
  <view class="modal-header">
    <text class="modal-title">修改密码</text>
    <text class="modal-close" bindtap="closePasswordModal">×</text>
  </view>
  <view class="modal-content">
    <view class="form-group">
      <text class="form-label">原密码</text>
      <input class="form-input" placeholder="请输入原密码" password="{{!showOldPassword}}" value="{{passwordForm.oldPassword}}" bindinput="onOldPasswordInput" />
    </view>
    <view class="form-group">
      <text class="form-label">新密码</text>
      <input class="form-input" placeholder="请输入新密码（至少6位）" password="{{!showNewPassword}}" value="{{passwordForm.newPassword}}" bindinput="onNewPasswordInput" />
    </view>
    <view class="form-group">
      <text class="form-label">确认密码</text>
      <input class="form-input" placeholder="请再次输入新密码" password="{{!showConfirmPassword}}" value="{{passwordForm.confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="closePasswordModal">取消</button>
    <button class="btn-confirm" bindtap="savePassword" loading="{{saving}}">确认修改</button>
  </view>
</view>
